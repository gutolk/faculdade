<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="CALCULAGAS"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblVeiculo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Selecione o veículo:"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Spinner
        android:id="@+id/spinnerVeiculo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:entries="@array/opcoes_veiculo"
        app:layout_constraintTop_toBottomOf="@id/lblVeiculo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblCombustivel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tipo de combustível:"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/spinnerVeiculo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <RadioGroup
        android:id="@+id/radioGroupCombustivel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblCombustivel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/radioEtanol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Etanol"
            android:layout_weight="1"/>

        <RadioButton
            android:id="@+id/radioGasolina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gasolina"
            android:layout_weight="1"/>

        <RadioButton
            android:id="@+id/radioDiesel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diesel"
            android:layout_weight="1"/>

    </RadioGroup>

    <TextView
        android:id="@+id/lblLitros"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Quantos litros vai abastecer?"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/radioGroupCombustivel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtLitros"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Ex: 40"
        android:inputType="numberDecimal"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblLitros"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblDistancia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Distância da viagem (km):"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/edtLitros"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtDistancia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Ex: 300"
        android:inputType="numberDecimal"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblDistancia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblConsumo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Consumo do veículo (km/l):"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/edtDistancia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtConsumo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Ex: 12"
        android:inputType="numberDecimal"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblConsumo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnEnviar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="CALCULAR"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/edtConsumo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>